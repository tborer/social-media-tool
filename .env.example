# Database
DATABASE_URL=postgresql://user:password@host:port/database
DIRECT_URL=postgresql://user:password@host:port/database

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# Instagram OAuth (REQUIRED for Instagram OAuth flow - Phase 1.2)
# Get these from Meta for Developers: https://developers.facebook.com/apps/
INSTAGRAM_APP_ID=xxx
INSTAGRAM_APP_SECRET=xxx
INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/auth/instagram/callback

# LinkedIn OAuth (REQUIRED for LinkedIn account connection - Phase 4, Feature 6)
# Get these from LinkedIn Developer Portal: https://developer.linkedin.com/
# Required scopes: openid, profile, email, w_member_social
# Set the authorized redirect URL in your LinkedIn app to match LINKEDIN_REDIRECT_URI
LINKEDIN_CLIENT_ID=xxx
LINKEDIN_CLIENT_SECRET=xxx
LINKEDIN_REDIRECT_URI=https://your-domain.com/api/auth/linkedin/callback

# X (Twitter) OAuth 2.0 (REQUIRED for X account connection - Phase 4, Feature 6)
# Get these from the X Developer Portal: https://developer.twitter.com/
# App type: Web App / Confidential Client (to get a client secret)
# Required scopes: tweet.read, tweet.write, users.read, offline.access
# Set the callback URL in your X app to match X_REDIRECT_URI
X_CLIENT_ID=xxx
X_CLIENT_SECRET=xxx
X_REDIRECT_URI=https://your-domain.com/api/auth/x/callback

# AI Services
GEMINI_API_KEY=xxx
OPENAI_API_KEY=xxx

# Google Nano Banana (to be added when available)
# NANO_BANANA_API_KEY=xxx
# NANO_BANANA_BASE_URL=xxx

# Token Encryption (HIGHLY RECOMMENDED for security - Phase 1.2)
# Encrypts Instagram access tokens at rest in the database
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_encryption_key

# Scheduler Cron Secret (REQUIRED for scheduling automation - Phase 1.1)
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_key_here

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
