generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String               @id @db.Uuid
  email              String               @unique
  createdAt          DateTime             @default(now())
  socialMediaAccounts SocialMediaAccount[]
  contentPosts       ContentPost[]
  userSettings       UserSettings?
  logs               Log[]
  urlMappings        UrlMapping[]
  contentIdeas       ContentIdea[]
  trackedHashtags    TrackedHashtag[]
  trackedCompetitors TrackedCompetitor[]
  contacts           Contact[]
  outreachMessages   OutreachMessage[]
  outreachCriteria   OutreachCriteria[]
}

model SocialMediaAccount {
  id                     String        @id @default(uuid())
  username               String
  accessToken            String
  refreshToken           String?       // Used by X (rotated on each use, encrypted)
  isEncrypted            Boolean       @default(false)
  tokenExpiresAt         DateTime?
  accountType            AccountType   @default(INSTAGRAM)
  linkedinUserId         String?       // LinkedIn member URN, e.g. "urn:li:person:{id}"
  linkedinOrganizationId String?       // LinkedIn org URN for company page posting (optional)
  xUserId                String?       // X numeric user ID
  userId                 String        @db.Uuid
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  contentPosts           ContentPost[]
  accountInsights        AccountInsight[]

  @@unique([userId, username, accountType])
}

enum AccountType {
  INSTAGRAM
  LINKEDIN
  BLUESKY
  X
}

model ContentPost {
  id                   String             @id @default(uuid())
  caption              String
  imageUrl             String?
  contentType          ContentType        @default(IMAGE)
  videoType            VideoType?         // Type of video: FEED or REELS (for Instagram)
  status               PostStatus         @default(DRAFT)
  scheduledFor         DateTime?
  targetPlatforms      String[]           // e.g. ["INSTAGRAM", "LINKEDIN"] — set at creation time
  retryCount           Int                @default(0)
  lastRetryAt          DateTime?
  errorMessage         String?
  igMediaId            String?            // Instagram media ID after publishing
  linkedinPostId       String?            // LinkedIn post URN after publishing
  xPostId              String?            // X tweet ID after publishing
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  userId               String             @db.Uuid
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialMediaAccountId String?
  socialMediaAccount   SocialMediaAccount? @relation(fields: [socialMediaAccountId], references: [id], onDelete: SetNull)
  postInsights         PostInsight[]
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum ContentType {
  IMAGE
  VIDEO
  BLOG_POST
}

enum VideoType {
  FEED
  REELS
}

enum LogType {
  CONTENT_POST
  AI_GENERATION
}

model Log {
  id          String    @id @default(uuid())
  type        LogType
  endpoint    String
  requestData Json
  response    Json?
  status      Int?
  error       String?
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model UserSettings {
  id                String    @id @default(uuid())
  userId            String    @unique @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  openaiApiKey      String?
  geminiApiKey      String?
  openaiMonthlyLimit Int      @default(100)
  geminiMonthlyLimit Int      @default(100)
  openaiUsageCount  Int       @default(0)
  geminiUsageCount  Int       @default(0)
  usageResetDate    DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model PostInsight {
  id          String   @id @default(uuid())
  postId      String
  post        ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  impressions Int      @default(0)
  reach       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  engagement  Float    @default(0) // Calculated engagement rate
  fetchedAt   DateTime @default(now())

  @@index([postId])
}

model AccountInsight {
  id            String             @id @default(uuid())
  accountId     String
  account       SocialMediaAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  followers     Int                @default(0)
  following     Int                @default(0)
  mediaCount    Int                @default(0)
  profileViews  Int                @default(0)
  websiteClicks Int                @default(0)
  fetchedAt     DateTime           @default(now())

  @@index([accountId])
}

enum IdeaStatus {
  NEW
  IN_PROGRESS
  USED
  ARCHIVED
}

model ContentIdea {
  id                String     @id @default(uuid())
  userId            String     @db.Uuid
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUrl         String?
  sourceAccountName String?
  sourceCaption     String?
  sourceImageUrl    String?
  sourceLikes       Int?
  sourceComments    Int?
  notes             String?
  tags              String[]   // Array of tag strings
  status            IdeaStatus @default(NEW)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([userId])
}

model TrackedHashtag {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashtag   String
  postCount Int?     // Last known post count
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, hashtag])
  @@index([userId])
}

model TrackedCompetitor {
  id            String   @id @default(uuid())
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  igUserId      String?
  username      String
  followerCount Int?
  mediaCount    Int?
  bio           String?
  lastFetchedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, username])
  @@index([userId])
}

enum ContactStatus {
  PROSPECT
  CONTACTED
  RESPONDED
  CONVERTED
  INACTIVE
}

enum OutreachMessageStatus {
  DRAFT
  SENT
  REPLIED
  NO_REPLY
}

model Contact {
  id              String        @id @default(uuid())
  userId          String        @db.Uuid
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  igUsername       String
  igUserId        String?
  displayName     String?
  niche           String?
  location        String?
  followerCount   Int?
  engagementRate  Float?
  bio             String?
  notes           String?
  status          ContactStatus @default(PROSPECT)
  lastContactedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  outreachMessages OutreachMessage[]

  @@unique([userId, igUsername])
  @@index([userId])
  @@index([userId, status])
}

model OutreachMessage {
  id                String                @id @default(uuid())
  userId            String                @db.Uuid
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId         String
  contact           Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messageBody       String
  templateName      String?
  status            OutreachMessageStatus @default(DRAFT)
  sentAt            DateTime?
  responseReceivedAt DateTime?
  responseNotes     String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([userId])
  @@index([contactId])
}

model OutreachCriteria {
  id            String   @id @default(uuid())
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  searchTerms   String[]
  locations     String[]
  niches        String[]
  followerMin   Int?
  followerMax   Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model UrlMapping {
  id            String    @id @default(uuid())
  short_id      String    @unique
  original_path String
  user_id       String    @db.Uuid
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  file_name     String
  mime_type     String
  created_at    DateTime  @default(now())
  accessed_at   DateTime?
  access_count  Int       @default(0)
}